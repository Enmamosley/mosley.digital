---
import { markdownify } from "@/lib/utils/textConverter";

interface Props {
  feature: {
    title: string;
    icon?: string;
    link?: string;
  };
}

const { feature }: Props = Astro.props;
const Tag = feature.link ? "a" : "div";
---

<Tag
  href={feature.link}
  class="group bg-light card-shadow relative flex h-full min-h-24 w-full items-center overflow-hidden rounded-2xl py-5 pr-10 pl-6 transition-all duration-500 hover:-translate-y-1"
>
  {/* left accent bar */}
  <span
    class="bg-primary/60 group-hover:bg-primary absolute top-5 bottom-5 left-3 w-1 rounded-full transition-all duration-500 group-hover:top-4 group-hover:bottom-4"
  ></span>

  <h3
    class="text-text-dark text-base leading-snug font-medium text-balance"
    set:html={markdownify(feature.title)}
  />

  {/* arrow — reveals on hover */}
  <span
    class="bg-primary text-light absolute right-3 bottom-3 flex size-7 translate-x-2 items-center justify-center rounded-full opacity-0 transition-all duration-500 group-hover:translate-x-0 group-hover:opacity-100"
    aria-hidden="true"
  >
    <svg
      width="16"
      height="16"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2.5"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <path d="M5 12h14M13 6l6 6-6 6"></path>
    </svg>
  </span>
</Tag>
