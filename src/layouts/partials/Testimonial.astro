---
import ImageMod from "@/components/ImageMod.astro";
import Title from "@/components/Title.astro";
import ScrollAnimation from "@/helpers/ScrollAnimation";
import { getListPage } from "@/lib/contentParser.astro";

const sectionData = await getListPage("testimonialSection", "testimonial");
if (!sectionData.data.enable) return null;

const { title, testimonials, client_logos } = sectionData.data;
const isHome = Astro.props.isHome || false;
---

<section class={`section ${!isHome ? "bg-gradient-tertiary rounded-4xl" : ""}`}>
  <div class="container">

    <!-- Header -->
    <ScrollAnimation client:visible>
      <div class="mx-auto max-w-2xl text-center mb-4">
        <Title title={title} />
      </div>
    </ScrollAnimation>

    <!-- Masonry columns layout (Tailwind Plus style) -->
    <div class="mx-auto mt-16 flow-root sm:mt-20">
      <div class="-mt-8 sm:-mx-4 sm:columns-2 sm:text-[0] lg:columns-3">
        {
          testimonials.map((item: any) => (
            <div class="pt-8 sm:inline-block sm:w-full sm:px-4">
              <figure class="rounded-2xl bg-light p-8 text-sm/6 card-shadow">
                <blockquote class="text-text-dark/80">
                  <p>"{item.content}"</p>
                </blockquote>
                <figcaption class="mt-6 flex items-center gap-x-4">
                  <div class="min-w-0">
                    <div class="font-semibold text-text-dark truncate">{item.name}</div>
                    <div class="text-text-dark/50 truncate">{item.designation}</div>
                  </div>
                </figcaption>
              </figure>
            </div>
          ))
        }
      </div>
    </div>

    <!-- Client logos -->
    {
      client_logos && client_logos.length > 0 && (
        <ScrollAnimation client:visible delay={0.2}>
          <div class="mt-20 pt-16 border-t border-dark/10">
            <div class="flex flex-wrap justify-center items-center gap-x-14 gap-y-8">
              {client_logos.map((logo: string, index: number) => (
                <div class="h-10 flex items-center">
                  <ImageMod
                    src={logo}
                    width={160}
                    height={40}
                    alt={`Cliente ${index + 1}`}
                    class="max-h-full w-auto object-contain grayscale opacity-60 hover:opacity-100 hover:grayscale-0 transition-all duration-300"
                  />
                </div>
              ))}
            </div>
          </div>
        </ScrollAnimation>
      )
    }

  </div>
</section>
