---
import ImageMod from "@/components/ImageMod.astro";
import Title from "@/components/Title.astro";
import ScrollAnimation from "@/helpers/ScrollAnimation";
import { markdownify } from "@/lib/utils/textConverter";
import type { CollectionEntry } from "astro:content";

type Props = {
  data: CollectionEntry<"homePage">["data"]["the_standard"];
};

const { data } = Astro.props;
---

<section class="section">
  <div class="container">
    <ScrollAnimation client:visible>
      <Title title={data.title} />
    </ScrollAnimation>

    <div class="grid lg:grid-cols-2 xl:grid-cols-3 gap-6">
      {
        data.list.map((item, index) => (
          <ScrollAnimation
            client:visible
            stagger={index + 1}
            delay={index * 0.2}
          >
            <div
              class={`bg-light px-9 py-8 rounded-2xl flex flex-col gap-y-18.5 h-full card-shadow`}
            >
              <div
                class={"flex flex-col gap-y-6 " + (index === 1 && " order-2")}
              >
                <h3 class="gradient-text" set:html={markdownify(item.title)} />
                <p
                  class="text-xl text-text-dark/90"
                  set:html={markdownify(item.content)}
                />

                {item?.bullet_points && (
                  <ul class="flex flex-col gap-y-3">
                    {item?.bullet_points.map((point: string) => (
                      <li class="flex items-start gap-x-2">
                        <ImageMod
                          src={"/images/icons/check-icon.svg"}
                          width={20}
                          height={20}
                          alt="check icon"
                          class="w-4 h-4 shrink-0 mt-1 sm:mt-0.75"
                        />
                        <span class="font-semibold">{point}</span>
                      </li>
                    ))}
                  </ul>
                )}
              </div>

              <div class={index === 1 ? " order-1 mb-auto" : "mt-auto"}>
                <ImageMod
                  src={item.icon}
                  width={400}
                  height={300}
                  alt={item.title}
                  class="h-34 w-auto"
                />
              </div>
            </div>
          </ScrollAnimation>
        ))
      }
    </div>
  </div>
</section>
