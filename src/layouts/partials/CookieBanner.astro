<div
  id="cookie-banner"
  class="fixed bottom-0 inset-x-0 z-50 bg-dark/95 backdrop-blur-sm border-t border-white/10 hidden"
>
  <div class="container flex items-center gap-4 py-2.5 flex-wrap sm:flex-nowrap">
    <p class="text-xs text-light/70 flex-1 min-w-0">
      Usamos cookies de analítica para mejorar tu experiencia.
      <a href="/privacy" class="underline underline-offset-2 text-light/90 ml-1 hover:text-light transition-colors">Más información</a>
    </p>
    <div class="flex items-center gap-2 shrink-0">
      <button
        id="cookie-reject"
        type="button"
        class="text-xs px-3 py-1.5 rounded-full border border-light/30 text-light/80 hover:bg-white/10 transition-colors cursor-pointer"
      >
        Rechazar
      </button>
      <button
        id="cookie-accept"
        type="button"
        class="text-xs px-3 py-1.5 rounded-full bg-primary text-light font-medium hover:opacity-90 transition-opacity cursor-pointer"
      >
        Aceptar
      </button>
    </div>
  </div>
</div>

<script>
  const CONSENT_KEY = "mosley_cookie_consent";

  function initCookieBanner() {
    const banner = document.getElementById("cookie-banner");
    const accept = document.getElementById("cookie-accept");
    const reject = document.getElementById("cookie-reject");

    if (!banner || !accept || !reject) return;

    if (!localStorage.getItem(CONSENT_KEY)) {
      banner.classList.remove("hidden");
    }

    accept.addEventListener("click", () => {
      localStorage.setItem(CONSENT_KEY, "accepted");
      banner.classList.add("hidden");
    });

    reject.addEventListener("click", () => {
      localStorage.setItem(CONSENT_KEY, "rejected");
      banner.classList.add("hidden");
    });
  }

  initCookieBanner();
  document.addEventListener("astro:after-swap", initCookieBanner);
</script>
