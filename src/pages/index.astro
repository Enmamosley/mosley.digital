---
import Base from "@/layouts/Base.astro";
import { getListPage, getSinglePage } from "@/lib/contentParser.astro";
import BookCall from "@/partials/BookCall.astro";
import CallToAction from "@/partials/CallToAction.astro";
import ChooseUs from "@/partials/ChooseUs.astro";
import FAQs from "@/partials/FAQs.astro";
import GetProjectDone from "@/partials/GetProjectDone.astro";
import Hero from "@/partials/Hero.astro";
import Pricing from "@/partials/Pricing.astro";
import Testimonial from "@/partials/Testimonial.astro";
import TheStandard from "@/partials/TheStandard.astro";
import WorkSwiper from "@/partials/WorkSwiper.astro";

const homepage = await getListPage("homePage", "-index");

const { banner, features, the_standard, recent_work, ready_to_choose_us } =
  homepage.data;

const workList = (await getSinglePage("workSinglePage")).sort((a, b) => {
  const wa = a.data.weight ?? 99;
  const wb = b.data.weight ?? 99;
  return wa - wb;
});
---

<Base>
  <Hero banner={banner} features={features} />
  <TheStandard data={the_standard} />
  <WorkSwiper data={recent_work} work={workList} />
  <BookCall />
  <GetProjectDone />
  <Testimonial isHome={true} />
  <Pricing />
  <ChooseUs data={ready_to_choose_us} />
  <FAQs />
  <CallToAction />
</Base>
