---
import WorkCard from "@/components/WorkCard.astro";
import ScrollAnimation from "@/helpers/ScrollAnimation";
import Base from "@/layouts/Base.astro";
import { getListPage, getSinglePage } from "@/lib/contentParser.astro";
import CallToAction from "@/partials/CallToAction.astro";
import PageHeader from "@/partials/PageHeader.astro";

const pageIndex = await getListPage("workListPage", "-index");
if (pageIndex.data.draft) {
  return Astro.redirect("/404");
}

const workList = (await getSinglePage("workSinglePage")).sort((a, b) => {
  const wa = a.data.weight ?? 99;
  const wb = b.data.weight ?? 99;
  return wa - wb;
});

const { title, page_header } = pageIndex.data;
---

<Base {...pageIndex.data}>
  <PageHeader
    title={page_header?.title || title}
    subtitle={page_header?.subtitle}
    badge={page_header?.badge}
  />

  <section class="pb-20">
    <div class="container">
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
        {
          workList.map((work, index) => (
            <ScrollAnimation client:visible delay={0.1 + index * 0.08}>
              <WorkCard work={work} compact />
            </ScrollAnimation>
          ))
        }
      </div>
    </div>
  </section>

  <CallToAction />
</Base>
