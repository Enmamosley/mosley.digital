---
import IconButton from "@/components/functional-components/IconButton";
import ImageMod from "@/components/ImageMod.astro";
import ScrollAnimation from "@/helpers/ScrollAnimation";
import Base from "@/layouts/Base.astro";
import { getSinglePage } from "@/lib/contentParser.astro";
import CallToAction from "@/partials/CallToAction.astro";
import { FaCheck, FaPhone } from "react-icons/fa6";

export async function getStaticPaths() {
  const services = await getSinglePage("serviceSinglePage");
  return services.map((service) => ({
    params: { single: service.id },
    props: { service },
  }));
}

const { service } = Astro.props;
const { title, meta_title, description, subtitle, intro, features, pricing, faq, technologies } =
  service.data;

const allServices = await getSinglePage("serviceSinglePage");
const otherServices = allServices.filter((s) => s.id !== service.id).slice(0, 3);
---

<Base {title} meta_title={meta_title || title} {description}>
  {/* Hero */}
  <section class="pt-40 pb-16">
    <div class="container">
      <ScrollAnimation client:visible>
        <div class="max-w-2xl">
          <span class="text-primary text-sm font-medium uppercase tracking-widest">Servicio</span>
          <h1 class="text-4xl md:text-5xl font-normal text-text-dark mt-3 mb-5 text-balance leading-tight">
            {title}
          </h1>
          <p class="text-lg text-text-dark/60 italic font-secondary mb-6">{subtitle}</p>
          <p class="text-base text-text-dark/80 leading-relaxed">{intro}</p>
        </div>
      </ScrollAnimation>
    </div>
  </section>

  {/* Features */}
  <section class="py-16 bg-theme-light/30">
    <div class="container">
      <ScrollAnimation client:visible>
        <h2 class="text-2xl font-normal text-text-dark mb-10">
          Qué <em>incluye</em>
        </h2>
      </ScrollAnimation>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {features.map((feat, i) => (
          <ScrollAnimation client:visible delay={0.08 + i * 0.06}>
            <div class="bg-light rounded-2xl card-shadow p-6 h-full">
              <h3 class="text-base font-medium text-text-dark mb-2">{feat.title}</h3>
              <p class="text-sm text-text-dark/70 leading-relaxed">{feat.description}</p>
            </div>
          </ScrollAnimation>
        ))}
      </div>
    </div>
  </section>

  {/* Pricing — estilo "Precios claros, sin sorpresas" */}
  {pricing && pricing.length > 0 && (
    <section class="section pb-0 bg-light rounded-[60px] relative overflow-hidden" id="pricing">
      <ImageMod
        src="/images/shapes/dark-grid-box.png"
        alt="shape"
        class="size-full absolute inset-0 z-1 object-cover object-center"
        width={1920}
        height={1080}
      />
      <div class="absolute inset-0 size-full bg-linear-to-b from-light via-body via-[6.98%] to-tertiary z-0" />
      <div class="container relative z-2">
        <ScrollAnimation client:visible>
          <h2 class="has-em section-title text-center text-h1 mb-12">
            Precios claros,<br/>sin <em>sorpresas</em>
          </h2>
        </ScrollAnimation>

        <div class={`grid gap-6 mb-8 ${pricing.length === 1 ? "max-w-xl mx-auto" : pricing.length === 2 ? "sm:grid-cols-2 max-w-4xl mx-auto" : "md:grid-cols-2 lg:grid-cols-3"}`}>
          {pricing.map((plan, index) => (
            <ScrollAnimation client:visible delay={0.1 + index * 0.1}>
              <div class="rounded-[28px] p-6 relative overflow-hidden bg-linear-to-br from-[#faf4ff] via-[#faf4ff] to-[#cfd3ff]">

                {/* Dark gradient + texture overlay for first card */}
                {index === 0 && (
                  <div class="absolute size-full inset-0 bg-linear-to-br from-tertiary to-secondary" />
                )}
                {index === 0 && (
                  <div class="absolute size-full inset-0 mix-blend-multiply overflow-hidden">
                    <ImageMod
                      src="/images/shapes/pricing-shape.png"
                      alt="shape"
                      class="size-full object-cover object-top"
                      width={1920}
                      height={2080}
                      loading="lazy"
                    />
                  </div>
                )}
                <div class="absolute size-full inset-0 overflow-hidden">
                  <ImageMod
                    src="/images/shapes/dark-grid-box.png"
                    alt="shape"
                    class="size-full object-cover"
                    width={1920}
                    height={1080}
                    loading="lazy"
                  />
                </div>

                {/* Header card */}
                <div
                  class={index === 0
                    ? "border border-light/30 backdrop-blur-md h-min overflow-clip rounded-[18px] flex flex-col gap-4 w-full px-5 pt-5 pb-6 relative shadow-[inset_-4px_-4px_50px_#ffffff3d]"
                    : "border border-light backdrop-blur-md h-min overflow-clip flex flex-col gap-4 bg-[#eaeaea33] rounded-[18px] w-full px-5 pt-5 pb-6 relative shadow-[inset_-4px_-4px_50px_#4141411a]"}
                >
                  <div class="flex justify-between items-center gap-2">
                    <p class={`text-xl font-light ${index === 0 ? "text-light" : "text-text-dark"}`}>
                      {plan.name}
                    </p>
                    {plan.badge && (
                      <p class={`border border-light/3 min-w-28 h-min z-3 bg-linear-to-b from-light/0 to-light/12 rounded-full px-3 py-2 relative shadow-[inset_4px_4px_9px_#3d3d3d1a,inset_-4px_-4px_4px_#e4e4e440,0_8px_24px_#1d1d1d0a] font-light text-center text-sm ${index === 0 ? "text-light" : "gradient-text-primary"}`}>
                        {plan.badge}
                      </p>
                    )}
                  </div>
                  <h3 class={`text-h1 ${index === 0 ? "text-light" : "text-text-dark"}`}>
                    <span class={index === 1 ? "gradient-text-primary" : ""}>
                      {typeof plan.price === "number"
                        ? `${plan.price_prefix ?? "$"}${plan.price.toLocaleString()}`
                        : plan.price}
                    </span>
                    {plan.period && (
                      <span class="text-lg font-secondary tracking-wider capitalize italic font-light inline-block ml-2">
                        {plan.period}
                      </span>
                    )}
                  </h3>
                </div>

                {/* Dashed divider */}
                <div
                  class={`border-t border-dashed overflow-clip flex-none w-full relative [mask:linear-gradient(90deg,#0000_0%,#000_51.4333%,#0000_100%)] my-5 h-px ${index === 0 ? "border-light" : "border-dark"}`}
                />

                {/* Features + buttons card */}
                <div
                  class={index === 0
                    ? "border border-light/30 backdrop-blur-md h-min overflow-clip rounded-[18px] flex flex-col gap-4 w-full px-5 pt-5 pb-6 relative shadow-[inset_-4px_-4px_50px_#ffffff3d]"
                    : "border border-dark/10 backdrop-blur-md h-min overflow-clip flex flex-col gap-4 bg-[#eaeaea33] rounded-[18px] w-full px-5 pt-5 pb-6 relative shadow-[inset_-4px_-4px_50px_#4141411a]"}
                >
                  <h3 class={`font-secondary italic text-h4 tracking-wider font-normal ${index === 0 ? "text-light" : "text-text-dark"}`}>
                    Incluye
                  </h3>
                  <ul class={`flex flex-col gap-y-3 text-base ${index === 0 ? "text-light" : "text-text-dark"}`}>
                    {plan.highlights.map((item) => (
                      <li class="flex items-start gap-x-2">
                        {index === 0 ? (
                          <svg class="text-lg shrink-0 mt-1 sm:mt-0.75" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z" />
                          </svg>
                        ) : (
                          <ImageMod
                            src="/images/icons/check-icon.svg"
                            alt="check"
                            width={24}
                            height={24}
                            class="w-6 h-6 shrink-0 mt-1 sm:mt-0.75"
                          />
                        )}
                        {item}
                      </li>
                    ))}
                  </ul>
                  <div class="flex justify-center items-center gap-5 mt-5 flex-wrap sm:flex-nowrap">
                    <IconButton
                      client:visible
                      href={plan.button_link}
                      classNames="w-full !rounded-2xl text-lg"
                      variant="filled"
                    >
                      {plan.button_label}
                    </IconButton>
                    {plan.button2_link && plan.button2_label && (
                      <IconButton
                        client:visible
                        href={plan.button2_link}
                        classNames="w-full !rounded-2xl text-lg"
                        variant="outline"
                      >
                        {plan.button2_label}
                      </IconButton>
                    )}
                  </div>
                </div>

              </div>
            </ScrollAnimation>
          ))}
        </div>

        {/* Book a call strip */}
        <div class="pb-24">
          <div class="rounded-[28px] px-10 pt-10 pb-8 relative overflow-hidden">
            <div class="absolute size-full inset-0 bg-linear-to-br from-tertiary to-secondary z-0" />
            <div class="absolute size-full inset-0 mix-blend-multiply overflow-hidden z-0">
              <ImageMod src="/images/shapes/book-call-shape.png" alt="shape" class="size-full object-cover object-center" width={1920} height={2080} loading="lazy" />
            </div>
            <div class="absolute size-full inset-0 overflow-hidden z-0">
              <ImageMod src="/images/shapes/dark-grid-box.png" alt="shape" class="size-full object-cover" width={1920} height={1080} loading="lazy" />
            </div>
            <div class="flex justify-between items-center flex-wrap gap-y-8 relative z-4">
              <div class="flex flex-col gap-y-4">
                <h2 class="text-light text-h3 has-em">¿No sabes cuál plan es para ti?<br/><em>Platiquemos 15 minutos</em></h2>
                <ul class="flex items-center gap-4 flex-wrap">
                  {["Sin costo y sin compromiso", "Respuesta en menos de 24 horas"].map((item) => (
                    <li class="text-text-light text-xl flex items-center gap-2">
                      <FaCheck className="inline-block text-lg shrink-0" />{item}
                    </li>
                  ))}
                </ul>
              </div>
              <IconButton client:visible href="/contacto" variant="filled" classNames="shrink-0">
                <FaPhone className="inline-block mr-2 text-lg" />
                Contactar ahora
              </IconButton>
            </div>
          </div>
        </div>
      </div>
    </section>
  )}

  {/* Technologies */}
  {technologies && technologies.length > 0 && (
    <section class="py-10 border-t border-dark/10">
      <div class="container">
        <ScrollAnimation client:visible>
          <div class="flex flex-wrap items-center gap-3">
            <span class="text-sm text-text-dark/50 mr-2">Tecnologías:</span>
            {technologies.map((tech) => (
              <span class="text-sm text-text-dark/80 bg-light card-shadow rounded-full px-4 py-1.5 border border-dark/10">
                {tech}
              </span>
            ))}
          </div>
        </ScrollAnimation>
      </div>
    </section>
  )}

  {/* FAQ */}
  {faq && faq.length > 0 && (
    <section class="py-16 bg-theme-light/30">
      <div class="container">
        <ScrollAnimation client:visible>
          <h2 class="text-2xl font-normal text-text-dark mb-10">
            Preguntas <em>frecuentes</em>
          </h2>
        </ScrollAnimation>
        <div class="max-w-3xl flex flex-col gap-4">
          {faq.map((item, i) => (
            <ScrollAnimation client:visible delay={0.06 + i * 0.05}>
              <details class="group bg-light rounded-2xl card-shadow border border-dark/10 overflow-hidden">
                <summary class="flex items-center justify-between gap-4 cursor-pointer p-6 text-sm font-medium text-text-dark select-none list-none">
                  {item.question}
                  <span class="shrink-0 text-primary transition-transform duration-300 group-open:rotate-45">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                      <line x1="12" y1="5" x2="12" y2="19"></line>
                      <line x1="5" y1="12" x2="19" y2="12"></line>
                    </svg>
                  </span>
                </summary>
                <div class="px-6 pb-6 text-sm text-text-dark/70 leading-relaxed border-t border-dark/10 pt-4">
                  {item.answer}
                </div>
              </details>
            </ScrollAnimation>
          ))}
        </div>
      </div>
    </section>
  )}

  {/* Other services */}
  {otherServices.length > 0 && (
    <section class="py-16">
      <div class="container">
        <div class="border-t border-dark/10 pt-12">
          <ScrollAnimation client:visible>
            <h3 class="text-xl font-normal text-text-dark/60 mb-8">Otros servicios</h3>
          </ScrollAnimation>
          <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {otherServices.map((s, i) => (
              <ScrollAnimation client:visible delay={0.08 + i * 0.08}>
                <a
                  href={`/servicios/${s.id}`}
                  class="group bg-light card-shadow relative flex min-h-24 w-full items-center overflow-hidden rounded-2xl py-5 pr-10 pl-6 transition-all duration-500 hover:-translate-y-1 border border-dark/10"
                >
                  <span class="bg-primary/60 group-hover:bg-primary absolute top-5 bottom-5 left-3 w-1 rounded-full transition-all duration-500 group-hover:top-4 group-hover:bottom-4"></span>
                  <div>
                    <p class="text-base font-medium text-text-dark leading-snug">{s.data.title}</p>
                    <p class="text-xs text-text-dark/50 mt-1">{s.data.subtitle}</p>
                  </div>
                  <span class="bg-primary text-light absolute right-3 bottom-3 flex size-7 translate-x-2 items-center justify-center rounded-full opacity-0 transition-all duration-500 group-hover:translate-x-0 group-hover:opacity-100" aria-hidden="true">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M5 12h14M13 6l6 6-6 6"></path>
                    </svg>
                  </span>
                </a>
              </ScrollAnimation>
            ))}
          </div>
        </div>
      </div>
    </section>
  )}

  <CallToAction />
</Base>
