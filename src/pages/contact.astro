---
import IconButton from "@/components/functional-components/IconButton";
import ImageMod from "@/components/ImageMod.astro";
import config from "@/config/config.json";
import ScrollAnimation from "@/helpers/ScrollAnimation";
import Base from "@/layouts/Base.astro";
import { getListPage } from "@/lib/contentParser.astro";
import { markdownify } from "@/lib/utils/textConverter";
import PageHeader from "@/partials/PageHeader.astro";
import { FaPaperPlane, FaPhone } from "react-icons/fa6";

const pageIndex = await getListPage("contactPage", "-index");
if (pageIndex.data.draft) {
  return Astro.redirect("/404");
}

const { title, page_header, contact_form } = pageIndex.data;
const { contact_form_action, mail, phone } = config.params;
---

<Base {...pageIndex.data}>
  <PageHeader title={page_header?.title || title} badge={page_header?.badge} />

  <section>
    <div class="container">
      <ScrollAnimation client:visible delay={0.3}>
        <div class="relative p-8 lg:pl-20 rounded-4xl overflow-hidden">
          <ImageMod
            src="/images/shapes/call-to-action.jpeg"
            alt="shape"
            width={2248}
            height={1152}
            class="absolute inset-0 size-full"
          />
          <div class="grid lg:grid-cols-2 relative z-2 gap-y-12">
            <div class="flex flex-col justify-between">
              <h2
                set:html={markdownify(contact_form.title)}
                class="xl:text-[65px] text-light prose-em:font-secondary prose-em:italic xl:leading-none text-h1 py-6"
              />
              <div
                class="flex lg:text-h3 text-light font-secondary font-light gap-5 flex-col text-xl"
              >
                <a
                  href={`mailto:${mail}`}
                  class="hover:text-lime-500 transition flex items-center gap-x-3 duration-300"
                >
                  <FaPaperPlane className="lg:text-3xl" />
                  {mail}
                </a>
                <a
                  href={`tel:${phone}`}
                  class="hover:text-lime-500 duration-300 transition flex items-center gap-x-3"
                >
                  <FaPhone className="lg:text-3xl" />
                  {phone}
                </a>
              </div>
            </div>
            <div class="bg-light rounded-2xl p-6">
              <h2 class="section-title pb-6 mb-6 border-b-2 border-dark/70">
                Contacta <em>con nosotros</em>
              </h2>

              <form
                id="contact-form"
                action={contact_form_action}
                method="POST"
                class="flex flex-col"
              >
                <input
                  type="text"
                  name="website"
                  autocomplete="off"
                  tabindex="-1"
                  class="hidden"
                  aria-hidden="true"
                />
                <div class="grid sm:grid-cols-2 gap-4">
                  <div>
                    <label for="name" class="form-label">Nombre</label>
                    <input
                      type="text"
                      class="form-input"
                      placeholder="Ingresa tu nombre"
                      name="name"
                      id="name"
                      required
                    />
                  </div>
                  <div>
                    <label for="email" class="form-label">Correo</label>
                    <input
                      type="email"
                      class="form-input"
                      placeholder="Ingresa tu correo"
                      name="email"
                      id="email"
                      required
                    />
                  </div>
                  <div>
                    <label for="phone" class="form-label">Telefono</label>
                    <input
                      type="tel"
                      class="form-input"
                      placeholder="Ingresa tu telefono"
                      name="phone"
                      id="phone"
                      required
                    />
                  </div>
                  <div>
                    <label for="services" class="form-label">Servicio</label>
                    <select
                      name="services"
                      id="services"
                      class="form-input"
                      required
                    >
                      <option value="" class="text-text-dark/50">
                        Selecciona un servicio
                      </option>
                      {
                        contact_form.services.map((service: string) => (
                          <option value={service}>{service}</option>
                        ))
                      }
                    </select>
                  </div>
                </div>
                <div class="mt-4 mb-4">
                  <label for="message" class="form-label">Mensaje</label>
                  <textarea
                    name="message"
                    id="message"
                    class="form-input"
                    placeholder="Cuéntanos sobre tu proyecto"
                    required
                    rows={5}></textarea>
                </div>
                <label for="legal" class="mb-5 text-sm text-text-dark/80 flex items-start gap-2">
                  <input id="legal" name="legal" type="checkbox" class="mt-1" required />
                  <span>
                    Acepto la
                    <a href="/privacy" class="underline underline-offset-2"> politica de privacidad </a>
                    y los
                    <a href="/terms" class="underline underline-offset-2"> terminos y condiciones</a>.
                  </span>
                </label>
                <p id="contact-form-status" class="mb-4 text-sm hidden" />
                <IconButton client:visible classNames="py-4 font-light">
                  Enviar solicitud
                </IconButton>
              </form>
            </div>
          </div>
        </div>
      </ScrollAnimation>
    </div>
  </section>
</Base>

<script>
  function initContactForm() {
    const form = document.getElementById("contact-form") as HTMLFormElement | null;
    const status = document.getElementById("contact-form-status");

    if (!form || !status) return;

    const submitButton = form.querySelector("button") as HTMLButtonElement | null;

    form.addEventListener("submit", async (event) => {
      event.preventDefault();

      const data = new FormData(form);
      const trap = String(data.get("website") || "").trim();

      if (trap.length > 0) {
        return;
      }

      status.classList.remove("hidden", "text-lime-600", "text-red-600");
      status.classList.add("text-text-dark");
      status.textContent = "Enviando solicitud...";

      if (submitButton) {
        submitButton.setAttribute("disabled", "true");
      }

      try {
        const response = await fetch(form.action, {
          method: "POST",
          body: data,
          mode: "cors",
        });

        if (!response.ok) {
          throw new Error("Request failed");
        }

        form.reset();
        status.classList.remove("text-text-dark", "text-red-600");
        status.classList.add("text-lime-600");
        status.textContent = "Solicitud enviada. Te responderemos pronto.";
      } catch (error) {
        status.classList.remove("text-text-dark", "text-lime-600");
        status.classList.add("text-red-600");
        status.textContent =
          "No se pudo enviar por ahora. Intenta de nuevo o escribenos a hola@mosley.digital.";
      } finally {
        if (submitButton) {
          submitButton.removeAttribute("disabled");
        }
      }
    });
  }

  initContactForm();
  document.addEventListener("astro:after-swap", initContactForm);
</script>
